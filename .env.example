# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/sweep_console"

# ─── Auth (NextAuth) ─────────────────────────────────────────────────────────
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# ─── Arc Blockchain ──────────────────────────────────────────────────────────
# Arc testnet RPC (EVM-compatible)
ARC_TESTNET_RPC_URL="https://rpc-testnet.arc.io"
ARC_MAINNET_RPC_URL="https://rpc.arc.io"

# USDC contract address on Arc
USDC_ADDRESS_TESTNET="0x..."
USDC_ADDRESS_MAINNET="0x..."

# Subscription contract address (set after deployment)
SUBSCRIPTION_CONTRACT_TESTNET="0x..."
SUBSCRIPTION_CONTRACT_MAINNET="0x..."

# Platform private key for billing engine (calls renew() on contract)
PLATFORM_PRIVATE_KEY="0x..."

# Platform treasury wallet (receives platform fees)
PLATFORM_TREASURY_ADDRESS="0x..."

# ─── Platform Config ─────────────────────────────────────────────────────────
# Platform fee in basis points (100 = 1%)
PLATFORM_FEE_BPS=100

# ─── WalletConnect ───────────────────────────────────────────────────────────
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID="get-from-cloud.walletconnect.com"

# ─── Environment ─────────────────────────────────────────────────────────────
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_ARC_CHAIN_ID=12345
