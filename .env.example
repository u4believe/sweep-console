# ══════════════════════════════════════════════════════════════════
#  apps/api/.env  (Express backend — never exposed to browser)
# ══════════════════════════════════════════════════════════════════

# ─── Database ────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:6543/sweep_console?pgbouncer=true&sslmode=require"
DIRECT_URL="postgresql://user:password@localhost:5432/sweep_console?sslmode=require"

# ─── JWT Session ─────────────────────────────────────────────────
JWT_SECRET="generate-with: openssl rand -base64 32"

# ─── API key signing ─────────────────────────────────────────────
PLATFORM_API_SIGNING_SECRET="generate-with: openssl rand -hex 32"

# ─── Circle Programmable Wallets ─────────────────────────────────
CIRCLE_API_KEY="TEST_API_KEY:..."
CIRCLE_BASE_URL="https://api-sandbox.circle.com"
# W3S app ID for merchant user-controlled wallets (Circle Console → W3S)
NEXT_PUBLIC_CIRCLE_APP_ID="your-circle-app-id"
# Chain for merchant user-controlled wallets. Per the addendum this becomes
# ARC-TESTNET once Circle W3S supports Arc; ETH-SEPOLIA works in sandbox today.
CIRCLE_BLOCKCHAIN="ETH-SEPOLIA"
# Public URL Circle should POST transaction notifications to (ngrok in dev)
CIRCLE_WEBHOOK_URL="https://your-domain/circle-webhooks"

# ─── Arc Blockchain ──────────────────────────────────────────────
ARC_NETWORK="testnet" # "testnet" | "mainnet"
ARC_TESTNET_RPC_URL="https://rpc-testnet.arc.io"
ARC_MAINNET_RPC_URL="https://rpc.arc.io"
PLATFORM_PRIVATE_KEY="0x..."
PLATFORM_TREASURY_ADDRESS="0x..."
PLATFORM_FEE_BPS=100
# Deployed SubscriptionManager (packages/contracts: forge script script/Deploy.s.sol)
SUBSCRIPTION_MANAGER_ADDRESS="0x..."
# USDC token on Arc — defaults to the canonical Arc address if unset
# USDC_ADDRESS="0x3600000000000000000000000000000000000000"

# ─── Billing engine ──────────────────────────────────────────────
# Escrow hold on first payments / trial conversions — the only refund window
SETTLEMENT_WINDOW_HOURS=24
# Daily renewal sweep (cron syntax, default 2 AM)
BILLING_CRON_SCHEDULE="0 2 * * *"

# ─── Cross-chain checkout (CCTP V2, delegation-gated) ────────────
# Arc is the primary chain. When Arc is short, a subscriber who enabled cross-chain
# (one-time fee + ERC-7715 delegation) is funded from one of these source chains via
# CCTP V2. CCTP supports USDC on these testnets; BNB is USDC-incompatible and dropped.
SUPPORTED_SOURCE_CHAINS="base,arbitrum,optimism"
# One-time fee (USDC micro-units) charged when a subscriber enables cross-chain;
# funds the platform's gas + bridge-fee coverage. Default 1 USDC.
PLATFORM_SETUP_FEE_USDC=1000000
# Per-chain RPC overrides for the balance scanner / relayer
# RPC_URL_BASE="https://sepolia.base.org"
# RPC_URL_ARBITRUM="https://sepolia-rollup.arbitrum.io/rpc"
# RPC_URL_OPTIMISM="https://sepolia.optimism.io"

# ─── Email ───────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@example.com
SMTP_PASS=your-app-password
SMTP_FROM=you@example.com

# ─── App URL (for email verification + password-reset links) ─────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Google Sign-In (OAuth) ──────────────────────────────────────
# OAuth 2.0 Client ID from Google Cloud Console → APIs & Services →
# Credentials → "Create credentials" → "OAuth client ID" → "Web
# application". The backend uses it to confirm a Google access token
# was minted for THIS app (anti-replay). Same value as
# VITE_GOOGLE_CLIENT_ID below. Leaving it unset disables the audience
# check (dev only) — set it in production.
GOOGLE_CLIENT_ID="xxxxxxxxxxxx.apps.googleusercontent.com"

NODE_ENV="development"


# ══════════════════════════════════════════════════════════════════
#  apps/web/.env  (Vite frontend — only VITE_* vars reach browser)
# ══════════════════════════════════════════════════════════════════

VITE_API_URL="http://localhost:4000"
VITE_CIRCLE_APP_ID="your-circle-app-id"
VITE_PLATFORM_WALLET_ADDRESS="0x..."
VITE_WALLETCONNECT_PROJECT_ID="get-from-cloud.walletconnect.com"

# Google Sign-In client ID — SAME value as GOOGLE_CLIENT_ID above. In
# the OAuth client's "Authorized JavaScript origins" add your dev origin
# (http://localhost:3000) and your production origin. The "Sign up /
# Continue with Google" buttons stay inert until this is set.
VITE_GOOGLE_CLIENT_ID="xxxxxxxxxxxx.apps.googleusercontent.com"

# ─── Public analytics (Umami — optional, ad-blocker-resistant) ───
# Cookieless web analytics with a PUBLIC dashboard at /analytics. The tracker is
# served FIRST-PARTY (proxied via /insights → Umami) so ad-blockers don't block it.
# Self-host Umami (docker) or use Umami Cloud (https://umami.is), then:
#   1. Add your website → copy the Website ID.
#   2. Website → Edit → enable "Share URL" → copy the public share link.
# In PRODUCTION add a host rewrite: /insights/*  →  <VITE_UMAMI_HOST>/*
# (the Vite dev server proxies this automatically in development).
# VITE_UMAMI_WEBSITE_ID="00000000-0000-0000-0000-000000000000"
# VITE_UMAMI_SHARE_URL="https://cloud.umami.is/share/XXXXXXXX/your-site"
# VITE_UMAMI_HOST="https://cloud.umami.is"   # upstream proxied to (default; change if self-hosting)

# Optional — override default Arc RPC URLs
# VITE_ARC_TESTNET_RPC_URL="https://rpc-testnet.arc.io"
# VITE_ARC_MAINNET_RPC_URL="https://rpc.arc.io"

# ── Tier 2: ERC-7710 delegated cross-chain renewals (experimental, OFF) ──
# Client: enable the in-checkout "Enable automatic renewals" affordance. The
# component still self-gates on a runtime wallet-capability probe.
# VITE_TIER2_DELEGATION="true"
# The relayer address the subscriber delegates renewal authority to — MUST equal
# the public address of RENEWAL_DELEGATE_PRIVATE_KEY below.
# VITE_RENEWAL_DELEGATE_ADDRESS="0x..."

# Server: enable the flag-gated Tier-2 renewal cron pass.
# TIER2_DELEGATION="true"
# Key whose address holds the delegate role and submits redeemDelegations.
# Falls back to PLATFORM_PRIVATE_KEY if unset.
# RENEWAL_DELEGATE_PRIVATE_KEY="0x..."
# (Non-custodial: renewals CCTP-burn from the subscriber's OWN account to Arc —
# funds never touch a platform wallet. No collection address.)
# Per-chain RPC for redemption, keyed by chain id (e.g. Base Sepolia = 84532).
# DELEGATION_RPC_84532="https://sepolia.base.org"
# DELEGATION_RPC_5042002="https://rpc.testnet.arc.network/"
# CCTP v2 (validate addresses/domains/Iris at developers.circle.com/cctp): the
# TokenMessengerV2 per source chain (key matches SUPPORTED_SOURCE_CHAINS), the Arc
# MessageTransmitterV2, and the Iris attestation API. The V2 testnet contracts share
# one address across chains, so these overrides are only needed if Circle rotates them.
# CCTP_TOKEN_MESSENGER_BASE="0x..."
# CCTP_TOKEN_MESSENGER_OPTIMISM="0x..."
# CCTP_TOKEN_MESSENGER_ARBITRUM="0x..."
# CCTP_MESSAGE_TRANSMITTER_ARC="0x..."
# CCTP_IRIS_URL="https://iris-api-sandbox.circle.com"
# Fast Transfer fee cap as a share of the amount (bps). Must cover Circle's quoted
# Fast fee or the transfer degrades to Standard, and CCTP requires it < amount.
# Default 100 (1%). Both first payment AND renewals use Fast, so both honor this.
# CCTP_FAST_MAX_FEE_BPS="100"
# Renewal split on Arc (creator share + platform fee):
# PLATFORM_TREASURY_ADDRESS="0x..."
# PLATFORM_FEE_BPS="100"
